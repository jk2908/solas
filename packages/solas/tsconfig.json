{
	"compilerOptions": {
		"target": "ESNext",
		"lib": ["ESNext", "DOM"],
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"strict": true,
		"skipLibCheck": true,
		"jsx": "react-jsx",
		"jsxImportSource": "react",
		"allowSyntheticDefaultImports": true,
		"types": [
			"vite/client",
			"bun",
			"@vitejs/plugin-rsc/types",
			"network-information-types"
		],
		"declaration": true,
		"rootDir": "src",
		"outDir": "dist"
	},
	"include": ["src"]
}
