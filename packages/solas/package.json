{
	"name": "@jk2908/solas",
	"version": "0.2.2",
	"description": "A React Server Components meta-framework powered by Vite",
	"keywords": [
		"framework",
		"ppr",
		"react",
		"rsc",
		"ssr",
		"vite"
	],
	"homepage": "https://github.com/jk2908/solas/tree/main/packages/solas#readme",
	"bugs": {
		"url": "https://github.com/jk2908/solas/issues"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/jk2908/solas.git"
	},
	"bin": {
		"solas": "./dist/cli.js"
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./env/rsc": {
			"types": "./dist/internal/env/rsc.d.ts",
			"import": "./dist/internal/env/rsc.js"
		},
		"./env/ssr": {
			"types": "./dist/internal/env/ssr.d.ts",
			"import": "./dist/internal/env/ssr.js"
		},
		"./env/browser": {
			"types": "./dist/internal/env/browser.d.ts",
			"import": "./dist/internal/env/browser.js"
		},
		"./router": {
			"types": "./dist/router.d.ts",
			"import": "./dist/router.js"
		},
		"./navigation": {
			"types": "./dist/navigation.d.ts",
			"import": "./dist/navigation.js"
		},
		"./prerender": {
			"types": "./dist/prerender.d.ts",
			"import": "./dist/prerender.js"
		},
		"./server": {
			"types": "./dist/server.d.ts",
			"import": "./dist/server.js"
		},
		"./utils/logger": {
			"types": "./dist/utils/logger.d.ts",
			"import": "./dist/utils/logger.js"
		},
		"./error-boundary": {
			"types": "./dist/error-boundary.d.ts",
			"import": "./dist/error-boundary.js"
		},
		"./solas": {
			"types": "./dist/solas.d.ts",
			"import": "./dist/solas.js"
		}
	},
	"scripts": {
		"build": "rm -rf dist && tsgo && chmod +x dist/cli.js",
		"lint": "bunx oxlint .",
		"lint:fix": "bunx oxlint --fix .",
		"format": "bunx oxfmt --write .",
		"format:check": "bunx oxfmt --check .",
		"pack:dry": "npm pack --dry-run",
		"release:check": "npm run prepublishOnly",
		"prepublishOnly": "npm run build && npm run pack:dry"
	},
	"dependencies": {
		"@vitejs/plugin-rsc": "^0.5.20",
		"path-to-regexp": "^8.3.0",
		"rsc-html-stream": "^0.0.7"
	},
	"devDependencies": {
		"@prettier/plugin-oxc": "^0.1.3",
		"@types/bun": "^1.2.22",
		"@typescript/native-preview": "^7.0.0-dev.20260224.1",
		"network-information-types": "^0.1.1",
		"typescript": "^5.9.3"
	},
	"peerDependencies": {
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-server-dom-webpack": "^19.2.4",
		"vite": "^7.3.1 || ^8.0.0"
	},
	"peerDependenciesMeta": {
		"react-server-dom-webpack": {
			"optional": true
		}
	},
	"engines": {
		"bun": ">=1.2.0"
	}
}
