{
	"name": "@jk2908/drift",
	"version": "0.1.0",
	"bin": {
		"drift": "./dist/cli.js"
	},
	"files": [
		"dist"
	],
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./env/rsc": {
			"types": "./dist/internal/env/rsc.d.ts",
			"import": "./dist/internal/env/rsc.js"
		},
		"./env/ssr": {
			"types": "./dist/internal/env/ssr.d.ts",
			"import": "./dist/internal/env/ssr.js"
		},
		"./env/browser": {
			"types": "./dist/internal/env/browser.d.ts",
			"import": "./dist/internal/env/browser.js"
		},
		"./router": {
			"types": "./dist/router.d.ts",
			"import": "./dist/router.js"
		},
		"./navigation": {
			"types": "./dist/navigation.d.ts",
			"import": "./dist/navigation.js"
		},
		"./server": {
			"types": "./dist/server.d.ts",
			"import": "./dist/server.js"
		},
		"./error-boundary": {
			"types": "./dist/error-boundary.d.ts",
			"import": "./dist/error-boundary.js"
		},
		"./drift": {
			"types": "./dist/drift.d.ts",
			"import": "./dist/drift.js"
		}
	},
	"scripts": {
		"build": "rm -rf dist && bunx tsgo && chmod +x dist/cli.js",
		"lint": "bunx oxlint .",
		"lint:fix": "bunx oxlint --fix .",
		"format": "bunx oxfmt --write .",
		"format:check": "bunx oxfmt --check .",
		"pack:dry": "npm pack --dry-run",
		"prepublishOnly": "npm run build && npm run pack:dry"
	},
	"dependencies": {
		"client-only": "^0.0.1",
		"server-only": "^0.0.1"
	},
	"devDependencies": {
		"@prettier/plugin-oxc": "^0.1.3",
		"@types/dom-navigation": "^1.0.7",
		"@typescript/native-preview": "^7.0.0-dev.20260224.1"
	},
	"peerDependencies": {
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^5.1.4",
		"@vitejs/plugin-rsc": "^0.5.20",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-server-dom-webpack": "latest",
		"rsc-html-stream": "^0.0.7",
		"typescript": "^5.9.3",
		"vite": "^8.0.0-beta.15"
	},
	"peerDependenciesMeta": {
		"react-server-dom-webpack": {
			"optional": true
		}
	}
}
