{
	"name": "@jk2908/drift",
	"version": "0.1.0",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/types.d.ts",
	"scripts": {
		"build": "bunchee"
	},
	"dependencies": {
		"@vitejs/plugin-rsc": "^0.5.7",
		"devalue": "^5.1.1",
		"isbot": "^5.1.28",
		"rsc-html-stream": "^0.0.7"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.1.1",
		"@types/dom-navigation": "^1.0.6",
		"bunchee": "^6.5.4"
	},
	"peerDependencies": {
		"@types/react": "^19.2.3",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "latest",
		"react": "^19.2.3",
		"react-dom": "^19.2.3",
		"react-server-dom-webpack": "^19.2.3",
		"typescript": "^5.8.3",
		"vite": "^7.2.4"
	},
	"peerDependenciesMeta": {
		"react-server-dom-webpack": {
			"optional": true
		}
	},
	"exports": {
		".": {
			"types": "./dist/types.d.ts",
			"default": "./dist/index.js"
		},
		"./env/rsc": {
			"types": "./dist/env/rsc.d.ts",
			"default": "./dist/env/rsc.js"
