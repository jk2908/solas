		"./env/ssr": {
			"types": "./dist/env/ssr.d.ts",
			"default": "./dist/env/ssr.js"
		},
		"./env/browser": {
			"types": "./dist/env/browser.d.ts",
			"default": "./dist/env/browser.js"
		},
		"./router": {
			"types": "./dist/router.d.ts",
			"default": "./dist/router.js"
		},
		"./navigation": {
			"types": "./dist/navigation.d.ts",
			"default": "./dist/navigation.js"
		},
		"./ui/error-boundary": {
			"types": "./dist/error-boundary.d.ts",
			"default": "./dist/error-boundary.js"
		}
