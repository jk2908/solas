{
	"name": "@jk2908/drift",
	"version": "0.1.0",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"bin": {
		"drift": "./dist/cli.js"
	},
	"scripts": {
		"build": "rm -rf dist && tsc && chmod +x dist/cli.js"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.1.1",
		"@types/dom-navigation": "^1.0.6"
	},
	"peerDependencies": {
		"@types/react": "^19.2.3",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "latest",
		"@vitejs/plugin-rsc": "^0.5.7",
		"react": "^19.2.3",
		"react-dom": "^19.2.3",
		"rsc-html-stream": "^0.0.7",
		"react-server-dom-webpack": "^19.2.3",
		"typescript": "^5.8.3",
		"vite": "^7.3.1"
	},
	"peerDependenciesMeta": {
		"react-server-dom-webpack": {
			"optional": true
		}
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./env/rsc": {
			"types": "./dist/internal/env/rsc.d.ts",
			"import": "./dist/internal/env/rsc.js"
		},
		"./env/ssr": {
			"types": "./dist/internal/env/ssr.d.ts",
			"import": "./dist/internal/env/ssr.js"
		},
		"./env/browser": {
			"types": "./dist/internal/env/browser.d.ts",
			"import": "./dist/internal/env/browser.js"
		},
		"./router": {
			"types": "./dist/router.d.ts",
			"import": "./dist/router.js"
		},
		"./navigation": {
			"types": "./dist/navigation.d.ts",
			"import": "./dist/navigation.js"
		},
		"./server": {
			"types": "./dist/server.d.ts",
			"import": "./dist/server.js"
		},
		"./error-boundary": {
			"types": "./dist/error-boundary.d.ts",
			"import": "./dist/error-boundary.js"
		},
		"./config": {
			"types": "./dist/config.d.ts",
			"import": "./dist/config.js"
		}
	},
	"files": [
		"dist"
	]
}
