{
	"$schema": "./node_modules/oxlint/configuration_schema.json",
	"plugins": ["react", "react-perf", "jsx-a11y"],
	"categories": {
		"correctness": "error",
		"suspicious": "warn"
	},
	"rules": {
		"rules-of-hooks": "error",
		"exhaustive-deps": "warn",
		"no-shadow": "off",
		"react-in-jsx-scope": "off",
		"jsx-uses-react": "off",
		"jsx-key": "error",
		"jsx-no-constructed-context-values": "warn",
		"no-array-index-key": "warn",
		"jsx-no-new-function-as-prop": "off",
		"jsx-no-new-object-as-prop": "off",
		"jsx-no-new-array-as-prop": "off",
		"jsx-no-jsx-as-prop": "off",
		"button-has-type": "warn",
		"img-redundant-alt": "warn",
		"no-autofocus": "warn"
	},
	"overrides": [
		{
			"files": ["packages/solas/src/internal/server/**/*.ts"],
			"rules": {
				"rules-of-hooks": "off"
			}
		}
	],
	"ignorePatterns": ["**/dist/**", "**/.solas/**", "**/node_modules/**"]
}
