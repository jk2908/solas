{
	"name": "solas-monorepo",
	"version": "0.1.0",
	"private": true,
	"workspaces": [
		"packages/*",
		"examples/*"
	],
	"scripts": {
		"lint": "oxlint .",
		"lint:fix": "oxlint --fix .",
		"format": "oxfmt --write .",
		"format:check": "oxfmt --check .",
		"release:check": "npm run lint && npm run format:check && npm --prefix packages/solas run prepublishOnly",
		"release:version:patch": "npm version patch --workspace @jk2908/solas",
		"release:version:minor": "npm version minor --workspace @jk2908/solas",
		"release:version:major": "npm version major --workspace @jk2908/solas"
	},
	"devDependencies": {
		"@typescript/native-preview": "^7.0.0-dev.20260224.1",
		"oxfmt": "^0.35.0",
		"oxlint": "^1.50.0",
		"playwright": "^1.58.2",
		"typescript": "^5.9.3"
	}
}
